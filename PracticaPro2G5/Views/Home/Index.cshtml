@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center mb-5">
    <h1 class="display-5">Gestión de Productos Médicos</h1>
    <p class="lead text-muted">Sistema para administrar productos médicos y sus categorías.</p>
</div>

<div class="row justify-content-center g-4">
    <div class="col-md-5">
        <div class="card h-100 shadow-sm">
            <div class="card-body text-center">
                <h5 class="card-title">Categorías</h5>
                <p class="card-text text-muted">Cree, consulte, actualice y elimine categorías de productos.</p>
                <a class="btn btn-primary" asp-controller="Categoria" asp-action="Index">Ir a Categorías</a>
            </div>
        </div>
    </div>
    <div class="col-md-5">
        <div class="card h-100 shadow-sm">
            <div class="card-body text-center">
                <h5 class="card-title">Productos</h5>
                <p class="card-text text-muted">Administre los productos médicos y asígnelos a una categoría.</p>
                <a class="btn btn-primary" asp-controller="Producto" asp-action="Index">Ir a Productos</a>
            </div>
        </div>
    </div>
</div>
