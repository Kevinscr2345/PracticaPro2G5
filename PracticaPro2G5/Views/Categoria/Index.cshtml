@{
    ViewData["Title"] = "Categorías";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Categorías de productos</h1>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalCrearCategoria">
        <i class="bi bi-plus-lg"></i> Nueva categoría
    </button>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table id="tblCategorias" class="table table-striped table-hover w-100">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@await Html.PartialAsync("_Crear", new CategoriaDto())
@await Html.PartialAsync("_Editar", new CategoriaDto())

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/categoria.js" asp-append-version="true"></script>
}
